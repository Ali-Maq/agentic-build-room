# Panel — AI Runner config. Copy to `.env` and fill in.
# API keys live ONLY here (in the runner), never in the browser client or reducers.

# ---- LLM provider (default: gemini; works on the public internet today) ----
GEMINI_API_KEY=AIza...

# Optional alternate providers (see llm.ts). Only needed if you switch ROSTER off gemini.
# AZURE_API_KEY=...                 # Mount Sinai VPN-only gpt-5.4-pro
# OPENROUTER_API_KEY=...            # any model id (anthropic/*, openai/*, google/*)
# AWS_PROFILE=mssm-bedrock          # Claude via Bedrock (VPN-only)
# AWS_REGION=us-east-1
#
# Claude/Bedrock demo override:
# SOLVER_PROVIDER=bedrock
# SOLVER_MODEL=us.anthropic.claude-opus-4-8
# CRITIC_PROVIDER=bedrock
# CRITIC_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ---- SpacetimeDB connection ----
SPACETIMEDB_URI=ws://127.0.0.1:3456     # local; or wss://maincloud.spacetimedb.com
MODULE_NAME=panel                        # must match the published module name

# ---- Which room the runner hosts agents in / grades ----
ROOM_ID=                                 # u64 room id (from the lobby URL / room row)

# ---- Agent roster for this process ----
# One process hosts N agents. Either a full JSON spec (preferred) or a CSV of roles.
#
# AGENTS_JSON: array of agents. Each agent connects as its own identity (own token
# file ./.agent_token_<key>) and registers in the room.
#   key         : stable string used for the token filename + ROSTER lookup fallback
#   role        : ROSTER key -> (provider, model). e.g. solver | critic | verifier | human_llm
#   team        : 'human' | 'ai'
#   displayName : shown in the UI
#   pairedHuman : (optional) hex identity of the human this agent is steered by
#   provider    : (optional) override ROSTER provider
#   model       : (optional) override ROSTER model
#
# AGENTS_JSON=[{"key":"solver","role":"solver","team":"human","displayName":"Gemini Pro (solver)"},{"key":"critic","role":"critic","team":"ai","displayName":"Gemini Flash (critic)"}]
AGENTS_JSON=

# Simpler alternative: comma-separated ROSTER roles. team defaults to 'ai', names auto.
# AGENT_ROLES=solver,critic

# ---- Grader: recovering hidden tests / ground truth ----
# Code unit tests and ground-truth answers are deliberately NOT stored in the
# public bench_prompt row (that would leak the answer to the browser). For
# VERIFIED code grading the grader re-fetches them from Hugging Face. Give it the
# SAME row coordinates the task was loaded with so it grades the right problem.
# If unset, it falls back to the CATALOG entry's config/split for the dataset and
# a deterministic-ish row pick (which may differ from what the agents saw).
# BENCH_CONFIG=openai_humaneval
# BENCH_SPLIT=test
# BENCH_ROW_INDEX=0
# GRADE_TIMEOUT_MS=6000     # wall-clock cap for the sandboxed python run

# ---- Autonomous / race tuning ----
# AUTONOMOUS=false        # true -> seed a bootstrap intent per ai agent, no human needed
# MAX_ROUNDS=8            # per-agent edit cap to stop infinite loops
# TOKEN_BUDGET=200000     # total output-token budget across this process
# BOOTSTRAP_PROMPT=       # override the first autonomous intent text
